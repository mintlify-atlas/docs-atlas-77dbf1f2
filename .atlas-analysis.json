  "keyFeatures": [
    "POSIX/ANSI standards-compliant RTOS for 8-bit to 64-bit microcontrollers",
    "PX4 patches for Pixhawk flight controller hardware (STM32F4/F7/H7, i.MX RT, Kinetis)",
    "Highly configurable via Kconfig/menuconfig build system",
    "Comprehensive driver framework: USB, I2C, SPI, CAN, serial, networking",
    "Multiple filesystem support: FAT, ROMFS, LittleFS, SPIFFS, NXFFS",
    "TCP/IP networking stack with IPv4/IPv6, BSD sockets",
    "NuttShell (NSH): POSIX-like command-line shell for embedded targets",
    "Fully pre-emptible scheduler with fixed priority, round-robin, and sporadic scheduling",
    "Support for flat, protected (MPU), and kernel (MMU) memory configurations",
    "Graphics support: framebuffer, LCD drivers, NX windowing system"
  ],
  "publicApiSurface": [
    "task_create() / task_delete() — POSIX-like task management",
    "pthread_create() / pthread_join() — POSIX thread API",
    "open() / read() / write() / close() — VFS file operations",
    "socket() / bind() / connect() / send() / recv() — BSD socket API",
    "sem_init() / sem_wait() / sem_post() — POSIX semaphores",
    "mq_open() / mq_send() / mq_receive() — POSIX message queues",
    "register_driver() / register_blockdriver() — Driver registration",
    "up_irqinitialize() / irq_attach() — Interrupt management",
    "kmm_malloc() / kmm_free() — Kernel memory allocator",
    "tools/configure.sh <board>:<config> — Board configuration script"
  ]
}
